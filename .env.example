# Noctcom Self-Host Configuration
# 1. cp .env.example .env
# 2. Change ALL passwords below
# 3. Set CADDY_DOMAIN to your domain
# 4. docker compose up -d
#
# Las variables marcadas (opcional) pueden omitirse: tienen valor por defecto
# o desactivan una función sin romper el arranque. La fuente de la verdad del
# backend es backend/src/config.ts.

# ─── Domain and TLS ──────────────────────────────────────────────
CADDY_DOMAIN=example.com
CADDY_EMAIL=admin@example.com

# ─── Compose (install.sh lo añade automáticamente) ───────────────
# Fija qué ficheros usa 'docker compose' (evita el override de desarrollo,
# que publica puertos de postgres/redis/minio al host):
#   COMPOSE_FILE=docker-compose.yml                          # modo dominio (TLS)
#   COMPOSE_FILE=docker-compose.yml:docker-compose.lan.yml   # modo LAN por IP

# ─── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_DB=noctcom
POSTGRES_USER=noctcom
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

# ─── Redis ───────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_password

# ─── MinIO (S3-compatible blob storage) ──────────────────────────
MINIO_ROOT_USER=noctcom-admin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_BUCKET=noctcom-blobs

# ─── JWT (generate with: openssl rand -base64 64) ────────────────
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64

# ─── Public URLs (Caddy handles TLS automatically) ───────────────
PUBLIC_URL=https://api.example.com
PUBLIC_API_URL=https://api.example.com
FRONTEND_URL=https://app.example.com

# ─── Email (opcional — necesario para verificación de email/OTP) ─
# Opción A: Resend (recomendado). Si defines RESEND_API_KEY, se usa esta vía.
# RESEND_API_KEY=re_CHANGE_ME
# Opción B: SMTP cualquiera (fallback si no hay RESEND_API_KEY).
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_CHANGE_ME
SMTP_FROM=noreply@example.com

# ─── Límites y cuota (opcional — valores por defecto entre paréntesis) ─
# MAX_UPLOAD_BYTES=5368709120     # tamaño máx. por subida (5 GiB)
# USER_QUOTA_BYTES=1073741824     # cuota por usuario (1 GiB)
# Tope GLOBAL de almacenamiento cloud (suma de todos los usuarios). Protege el
# gasto en el object storage (B2/MinIO): al alcanzarlo, se rechazan subidas
# nuevas (HTTP 507). 0 = sin tope. Pon aquí el límite que aceptas pagar.
# GLOBAL_STORAGE_CAP_BYTES=0            # ej. 107374182400 = 100 GiB
# GLOBAL_STORAGE_ALERT_PCT=80           # % del tope que dispara el aviso (log + GlitchTip)

# ─── Lockout de logins fallidos (opcional — defaults entre paréntesis) ─
# Bloqueo temporal POR CUENTA tras varios fallos de contraseña; complementa el
# rate-limit por IP. Backoff exponencial en bloqueos consecutivos. Necesita Redis.
# LOGIN_LOCKOUT_MAX_FAILS=5             # fallos que activan el bloqueo
# LOGIN_LOCKOUT_WINDOW_S=900            # ventana de conteo (15 min)
# LOGIN_LOCKOUT_BASE_LOCK_S=900         # primer bloqueo (15 min; se duplica)
# LOGIN_LOCKOUT_MAX_LOCK_S=14400        # bloqueo máximo (4 h)

# ─── Agente "Noctcom Connector" (opcional) ───────────────────────
# Última versión publicada del agente; los agentes instalados la usan para
# detectar si hay actualización. Súbela al publicar un binario nuevo.
# AGENT_LATEST_VERSION=0.1.0

# ─── Notificaciones push / FCM (opcional) ────────────────────────
# Para avisos de "te han compartido un archivo" con la app cerrada.
# El service account de Firebase como JSON en base64:
#   base64 -w0 firebase-service-account.json
# Si se omite, las notificaciones push quedan desactivadas (todo lo demás va).
# FIREBASE_SERVICE_ACCOUNT_B64=

# ─── Error tracking / GlitchTip (opcional) ───────────────────────
# DSN de tu proyecto en GlitchTip (o Sentry). Si se omite, no se reporta nada.
# Solo se activa en producción.
# SENTRY_DSN=

# ═════════════════════════════════════════════════════════════════
# FRONTEND (Next.js) — variables NEXT_PUBLIC_*, se inyectan en BUILD-TIME.
# En el despliegue por imagen Docker van en frontend/Dockerfile, no aquí; esta
# sección documenta los valores para un build self-host propio.
# Son PÚBLICAS por diseño (acaban en el bundle del navegador).
# ═════════════════════════════════════════════════════════════════
# NEXT_PUBLIC_API_URL=https://api.example.com
# NEXT_PUBLIC_GTM_ID=                         # Google Tag Manager (opcional)
# Firebase web (push) — del proyecto Firebase, todas públicas:
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=             # clave VAPID web push
# NEXT_PUBLIC_SENTRY_DSN=                     # GlitchTip/Sentry del frontend (opcional)
