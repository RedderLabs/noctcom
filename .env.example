# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=noctcom
POSTGRES_USER=noctcom
POSTGRES_PASSWORD=__GENERATE_WITH__openssl_rand_-base64_32__

# ─── MinIO (S3-compatible) ────────────────────────────────────
MINIO_ROOT_USER=noctcom-admin
MINIO_ROOT_PASSWORD=__GENERATE_WITH__openssl_rand_-base64_32__
MINIO_BUCKET=noctcom-blobs
MINIO_CONSOLE_URL=https://minio.tu-dominio.com

# ─── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=__GENERATE_WITH__openssl_rand_-base64_32__

# ─── Backend ──────────────────────────────────────────────────
NODE_ENV=production
JWT_SECRET=__GENERATE_WITH__openssl_rand_-base64_64__
PUBLIC_URL=https://api.tu-dominio.com
PUBLIC_API_URL=https://api.tu-dominio.com
MAX_UPLOAD_BYTES=5368709120        # 5 GB por archivo
USER_QUOTA_BYTES=10737418240       # 10 GB por usuario por defecto

# ─── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=https://app.tu-dominio.com

# ─── Caddy ────────────────────────────────────────────────────
CADDY_DOMAIN=tu-dominio.com
CADDY_EMAIL=admin@tu-dominio.com

# ─── SMTP ─────────────────────────────────────────────────
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=465
SMTP_USER=noctcom
SMTP_PASS=__YOUR_SMTP_PASSWORD__
SMTP_FROM=noreply@tu-dominio.com
