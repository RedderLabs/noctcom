# Noctcom Self-Host Configuration
# 1. cp .env.example .env
# 2. Change ALL passwords below
# 3. Set CADDY_DOMAIN to your domain
# 4. docker compose up -d

# Domain and TLS
CADDY_DOMAIN=example.com
CADDY_EMAIL=admin@example.com

# PostgreSQL
POSTGRES_DB=noctcom
POSTGRES_USER=noctcom
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password

# MinIO (S3-compatible blob storage)
MINIO_ROOT_USER=noctcom-admin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_BUCKET=noctcom-blobs

# JWT (generate with: openssl rand -base64 64)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64

# Public URLs (Caddy handles TLS automatically)
PUBLIC_URL=https://api.example.com
PUBLIC_API_URL=https://api.example.com
FRONTEND_URL=https://app.example.com

# Email (optional - needed for email verification)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_CHANGE_ME
SMTP_FROM=noreply@example.com
