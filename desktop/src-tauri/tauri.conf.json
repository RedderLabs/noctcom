{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Noctcom",
  "version": "0.1.0",
  "identifier": "com.redderlabs.noctcom",
  "build": {
    "frontendDist": "../launcher"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "launcher",
        "title": "Noctcom",
        "width": 760,
        "height": 660,
        "minWidth": 520,
        "minHeight": 540,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
